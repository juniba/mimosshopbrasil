# Ativa o motor de reescrita de URLs do Apache
# HSTS - Força HTTPS por 1 ano
Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
# Compressão GZIP
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
# Cache-Control para assets estáticos
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
</IfModule>
RewriteEngine On

# Headers de segurança HTTP para proteger contra ataques comuns (caso o mod_headers esteja ativo)
# Comentário explicativo: a verificação <IfModule mod_headers.c> impede que o Apache quebre com erro 500 se o módulo de cabeçalhos não estiver instalado ou habilitado.
<IfModule mod_headers.c>
  # Bloqueia embedding em iframes de outros sites (proteção contra clickjacking)
  Header always set X-Frame-Options "SAMEORIGIN"
  # Previne que o navegador interprete MIME types incorretos
  Header always set X-Content-Type-Options "nosniff"
  # Ativa proteção nativa contra XSS no navegador
  Header always set X-XSS-Protection "1; mode=block"
  # Garante que referrer não vaze informações sensíveis
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  # Comentário de regra: CSP para mitigar XSS e injeções, autorizando fontes, scripts (Lucide/Supabase/GoogleAnalytics), imagens e conexões seguras
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://unpkg.com https://cdn.jsdelivr.net https://www.googletagmanager.com; style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://res.cloudinary.com https://*.supabase.co https://www.google-analytics.com https://www.googletagmanager.com; connect-src 'self' https://*.supabase.co https://www.google-analytics.com; frame-ancestors 'self';"
</IfModule>


# Impede que a regra de reescrita seja aplicada se o arquivo físico de fato existir
RewriteCond %{REQUEST_FILENAME} !-f

# Impede que a regra de reescrita seja aplicada se o diretório físico exato de fato existir
RewriteCond %{REQUEST_FILENAME} !-d

# Regra: Mapeia '/blog/qualquer-slug' para '/blog/index.php?slug=qualquer-slug'
# Isso possibilita links amigáveis e estruturados dentro do blog
RewriteRule ^blog/([a-zA-Z0-9-_]+)/?$ blog/index.php?slug=$1 [L,QSA]

# Regra: Mapeia '/sitemap.xml' para o script PHP dinâmico sitemap.php
# Permite que crawlers acessem o sitemap via URL padrão
RewriteRule ^sitemap\.xml$ sitemap.php [L]

