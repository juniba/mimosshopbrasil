# Arquivos de ambiente e caches locais que não devem ser enviados ao repositório Git
.env
cache/*
!cache/.gitkeep

# Exclui a pasta de scripts temporários e rascunhos (scratch/)
scratch/

# Exclui a pasta de dependências do Node.js
node_modules/

# Exclui o arquivo de log do WhatsApp gerado localmente
whatsapp_log.txt
